{
  "name": "book-test",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "misikt 教师端复刻 - 跨栈 E2E 回归测试套（Playwright）",
  "scripts": {
    "test": "playwright test --config=playwright.a.config.ts",
    "test:a": "playwright test --config=playwright.a.config.ts",
    "test:b": "playwright test --config=playwright.b.config.ts --workers=1",
    "test:a:system": "playwright test --config=playwright.a.config.ts a-line/system",
    "test:a:prd": "playwright test --config=playwright.a.config.ts a-line/prd",
    "test:prd001": "playwright test --config=playwright.a.config.ts a-line/prd/prd-a-001-paper-basket.spec.ts",
    "test:prd001:headed": "playwright test --config=playwright.a.config.ts a-line/prd/prd-a-001-paper-basket.spec.ts --headed",
    "test:prd002": "playwright test --config=playwright.a.config.ts a-line/prd/prd-a-002-profile-regression.spec.ts a-line/prd/prd-a-002-profile-acceptance.spec.ts",
    "test:prd002:headed": "playwright test --config=playwright.a.config.ts a-line/prd/prd-a-002-profile-regression.spec.ts a-line/prd/prd-a-002-profile-acceptance.spec.ts --headed",
    "test:prd005": "playwright test --config=playwright.a.config.ts a-line/prd/prd-a-005-acceptance.spec.ts a-line/prd/prd-a-005-permission-regression.spec.ts",
    "test:prd005:headed": "playwright test --config=playwright.a.config.ts a-line/prd/prd-a-005-acceptance.spec.ts a-line/prd/prd-a-005-permission-regression.spec.ts --headed",
    "test:prd006": "playwright test --config=playwright.a.config.ts a-line/prd/prd-a-006-merge-edit.spec.ts",
    "test:prd006:headed": "playwright test --config=playwright.a.config.ts a-line/prd/prd-a-006-merge-edit.spec.ts --headed",
    "test:prd007": "playwright test --config=playwright.a.config.ts a-line/prd/prd-a-007-workbench.spec.ts a-line/prd/prd-a-007-basket-strip.spec.ts",
    "test:prd007:headed": "playwright test --config=playwright.a.config.ts a-line/prd/prd-a-007-workbench.spec.ts a-line/prd/prd-a-007-basket-strip.spec.ts --headed",
    "test:headed": "playwright test --config=playwright.a.config.ts --headed",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.12.3",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0",
    "typescript": "~6.0.2"
  }
}
