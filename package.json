{
  "name": "book-test",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "misikt 教师端复刻 - 跨栈 E2E 回归测试套（Playwright）",
  "scripts": {
    "test": "playwright test",
    "test:prd001": "playwright test tests/prd-001-paper-basket.spec.ts",
    "test:prd001:headed": "playwright test tests/prd-001-paper-basket.spec.ts --headed",
    "test:prd002": "playwright test tests/prd-002-profile-regression.spec.ts tests/prd-002-profile-acceptance.spec.ts",
    "test:prd002:headed": "playwright test tests/prd-002-profile-regression.spec.ts tests/prd-002-profile-acceptance.spec.ts --headed",
    "test:v1": "playwright test tests/v1-question-bank-regression.spec.ts",
    "test:v1:headed": "playwright test tests/v1-question-bank-regression.spec.ts --headed",
    "test:v05": "playwright test tests/v05-paper-library.spec.ts",
    "test:v05:headed": "playwright test tests/v05-paper-library.spec.ts --headed",
    "test:u": "playwright test tests/u-teacher-user-workflow.spec.ts",
    "test:u:headed": "playwright test tests/u-teacher-user-workflow.spec.ts --headed",
    "test:q": "playwright test tests/q-compose-workbench.spec.ts",
    "test:q:headed": "playwright test tests/q-compose-workbench.spec.ts --headed",
    "test:q-prime": "playwright test tests/q-prime-paper-preview.spec.ts",
    "test:q-prime:headed": "playwright test tests/q-prime-paper-preview.spec.ts --headed",
    "test:v15h": "playwright test --config=playwright-admin.config.ts tests/v15h-question-crud-admin.spec.ts --workers=1",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.12.3",
    "playwright": "^1.60.0",
    "typescript": "~6.0.2"
  }
}
